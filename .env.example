# Docker 环境变量配置
# 复制此文件为 .env 并填入你的配置

# === 网易云音乐 ===
NETEASE_COOKIE=

# === Spotify ===
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# === QQ 音乐 ===
QQMUSIC_APP_ID=
QQMUSIC_APP_SECRET=

# === Apple Music ===
APPLE_DEVELOPER_TOKEN=
APPLE_KEY_ID=
APPLE_TEAM_ID=
APPLE_PRIVATE_KEY=

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === API 配置 ===
JIUGE_API_HOST=0.0.0.0
JIUGE_API_PORT=8000
JIUGE_DEBUG=false

# === 数据目录 ===
JIUGE_DATA_DIR=/app/data
JIUGE_MUSIC_DIR=/app/music
